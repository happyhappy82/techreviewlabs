                </div>
                )}
                {product.cons.length > 0 && (
                <div class="cons-block">
                  <h4>단점</h4>
                  <ul>
                    {product.cons.map(con => <li>{con}</li>)}
                  </ul>
                </div>
                )}
                {product.recommendFor.length > 0 && (
                  <div class="recommend-block">
                    <h4>이런 분께 추천합니다</h4>
                    <ul>
                      {product.recommendFor.map(r => <li>{r}</li>)}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </section>
      )}

      {selectionGuide && (
        <section class="section selection-guide">
          <h2>어떤 제품을 선택해야 할까요?</h2>
          {selectionGuide.split('\n').filter(p => p.trim()).map(p => (
            p.startsWith('•') || p.startsWith('-')
              ? <p class="guide-item">{p.replace(/^[•-]s*/, '')}</p>
              : <p>{p}</p>
          ))}
        </section>
      )}

      {comparisonData.length > 0 && (
      <section class="section">
        <h2>제품 비교표</h2>
        <div class="table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>항목</th>
                {comparisonData.map(p => <th>{p.name}</th>)}
              </tr>
            </thead>
            <tbody>
              {comparisonSpecs.map(spec => (
                <tr>
                  <th>{spec.label}</th>
                  {comparisonData.map(p => <td>{p[spec.key] || '-'}</td>)}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
      )}

      <section class="section closing">
        <h2>마무리</h2>
        <p>오늘은 '2026 250만원대 노트북 추천 Top5'에 대해 말씀드렸습니다. 오늘 소개해 드린 5가지 제품들은 각기 다른 매력을 지니고 있지만, 모두 250만원대라는 예산 안에서 최고 수준의 성능과 최신 기술을 제공한다는 공통점을 가지고 있습니다.
• 휴대성과 최고의 디스플레이를 원한다면: 에이수스 2025 ROG 제피러스 G14
• 압도적인 게이밍 성능과 스마트한 최적화를 원한다면: HP 2025 오멘 16 라이젠9
• 최상급 OLED 디스플레이와 강력한 성능의 가성비를 원한다면: 에이서 2025 프레데터 헬리오스 네오 16S AI 코어Ultra9
• 데스크탑 대용으로 높은 확장성과 합리적인 가격을 원한다면: 레노버 2025 LOQ 15IRX10 코어i7
• 최신 기술이 집약된 17인치 대화면 플래그십을 원한다면: MSI 2025 크로스헤어 A17 HX 라이젠9
어떤 제품을 선택하시든, 250만원대 노트북은 고사양 게임, 전문적인 크리에이티브 작업, 그리고 다가오는 AI 시대의 요구사항까지 충분히 만족시켜 줄 것입니다. 여러분의 사용 목적과 선호하는 브랜드, 디자인, 휴대성 등을 고려하여 신중하게 선택하신다면 후회 없는 구매가 되리라 확신합니다.
위 글 내용이 여러분들께 조금이라도 도움이 되길 바랍니다.</p>
      </section>

      {faqs.length > 0 && (
        <section class="section faq-section">
          <h2>자주 묻는 질문 (FAQ)</h2>
          <div class="faq-list">
            {faqs.map(faq => (
              <details class="faq-item">
                <summary>{faq.q}</summary>
                <p>{faq.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>
</BaseLayout>

<style>

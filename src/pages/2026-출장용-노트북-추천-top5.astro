];
const faqs = [
  {
    "q": "출장용 노트북인데 게이밍 노트북이 너무 무겁지 않을까요?",
    "a": "A. 네, 일반적인 사무용 노트북보다는 무겁습니다. 하지만 오늘 소개해 드린 제품들은 단순히 게임용을 넘어, 고성능 작업에 필요한 프로세서와 그래픽카드, 그리고 훌륭한 쿨링 시스템을 갖추고 있어 전문적인 업무용으로도 손색이 없습니다. 특히, 고성능 노트북은 출장 중에도 데스크톱 환경과 유사한 생산성을 제공하며, 여가 시간에는 게임이나 고화질 콘텐츠를 즐길 수 있다는 장점이 있습니다."
  },
  {
    "q": "FreeDOS 모델은 윈도우 설치가 어렵지 않나요?",
